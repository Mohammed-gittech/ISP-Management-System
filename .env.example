# ============================================
# ISP Management System - Environment Variables Template
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env (DO NOT commit .env!)
# 2. Replace <PLACEHOLDERS> with actual values
# 3. For Production: set these as Environment Variables
#
# ============================================

# ============================================
# Database Configuration
# ============================================

# SQL Server Connection String
ConnectionStrings__DefaultConnection=Server=localhost;Database=ISPManagementDB;User Id=sa;Password=<YOUR_DB_PASSWORD>;TrustServerCertificate=True;

# Hangfire Connection
ConnectionStrings__HangfireConnection=Server=localhost;Database=ISPManagementDB;User Id=sa;Password=<YOUR_DB_PASSWORD>;TrustServerCertificate=True;

# ============================================
# JWT Configuration
# ============================================

# JWT Secret Key (minimum 32 characters)
# Generate: openssl rand -base64 48
JWT__Key=<GENERATE_STRONG_KEY_AT_LEAST_32_CHARACTERS>

# JWT Issuer
JWT__Issuer=ISPManagementSystem

# JWT Audience
JWT__Audience=ISPManagementSystemUsers

# ============================================
# Environment
# ============================================

ASPNETCORE_ENVIRONMENT=Production

# ============================================
# Optional Settings
# ============================================

# Hangfire__DashboardPath=/hangfire
# Logging__LogLevel__Default=Information

# ============================================
# NOTES:
# ============================================
#
# Development:
#   - Use User Secrets: dotnet user-secrets
#   - .env for local Docker testing
#
# Production:
#   - Set Environment Variables on server
#   - Never commit .env with real passwords!
#
# ============================================