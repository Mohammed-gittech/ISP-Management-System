{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "HangfireConnection": ""
  },
  "JWT": {
    "Key": "",
    "Issuer": "",
    "Audience": ""
  },
  "BackgroundJobs": {
    "ExpiryCheckCron": "0 1 * * *",
    "RetryFailedCron": "0 */6 * * *",
    "StatusUpdateCron": "0 2 * * *"
  },
  "Telegram": {
    "DefaultTimeout": 30,
    "MaxRetries": 3
  },
  "SoftDelete": {
    "RetentionDays": 90,
    "CleanupUsers": false,
    "EnableRetentionCleanup": true
  },
  "RefreshTokens": {
    "RevokedRetentionDays": 90,
    "ExpiredRetentionDays": 90
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 5
  },

  "RateLimiting": {
    "Auth": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    }
  },

  "Cors": {
    "AllowedOrigins": ["https://alnoor.com", "https://app.alnoor.com"]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning",
      "ISP.Infrastructure.BackgroundJobs": "Information"
    }
  },

  "AllowedHosts": "*"
}
