{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ISPManagementDB;User Id=sa;Password=sa123456;TrustServerCertificate=True;",
    "HangfireConnection": "Server=localhost;Database=ISPManagementDB;User Id=sa;Password=sa123456;TrustServerCertificate=True;"
  },
  "JWT": {
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong",
    "Issuer": "ISPManagementSystem",
    "Audience": "ISPManagementSystemUsers"
  },
  "BackgroundJobs": {
    "ExpiryCheckCron": "0 1 * * *",
    "RetryFailedCron": "0 */6 * * *",
    "StatusUpdateCron": "0 2 * * *"
  },
  "Telegram": {
    "DefaultTimeout": 30,
    "MaxRetries": 3
  },
  "SoftDelete": {
    "RetentionDays": 90,
    "CleanupUsers": false,
    "EnableRetentionCleanup": true
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 5
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning",
      "ISP.Infrastructure.BackgroundJobs": "Information"
    }
  },

  "AllowedHosts": "*"
}
